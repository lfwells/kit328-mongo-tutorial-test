{
    "name": "KIT328 Codespace",
    "dockerComposeFile": "../docker-compose.yaml",
    
    "service": "frontend",

    // Magic Startup Commands
    "postCreateCommand": "git config --global core.hooksPath /dev/null",
    //"postStartCommand": "docker compose up -d",

    // Magic that makes the docker image work within the Codespace
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "moby": true
        },
    },
    
    // Magic that makes the git integration in VS Code actually work
    "customizations": {
        "vscode": {
            "settings": {           
                "git.path": "git"
            }
        }
    },

    // Forwarding ports and giving them names
    "forwardPorts": [3002, 5002],
    "portsAttributes": {
        "3002": {
            "label": "Frontend (React Dashboard)",
            "onAutoForward": "notify"
        },
        "5002": {
            "label": "Backend (Express API)",
            "onAutoForward": "silent"
        }
    }
}